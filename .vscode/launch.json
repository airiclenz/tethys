    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run API",
            "type": "python3",
            "request": "launch",
            "program": "${workspaceFolder}/api/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:5001"
            ],
            "django": true,
            "justMyCode": true
        },
        {
            "name": "Python: Run WEB",
            "type": "python3",
            "request": "launch",
            "program": "${workspaceFolder}/web/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:5000"
            ],
            "django": true,
            "justMyCode": true
        }
    ]
}