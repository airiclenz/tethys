server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name {HOST-NAME};
    root {TETHYS-PATH}/web/;
    
    location /static {
        alias /var/www/tethys/staticcollect;
    } 

    location / {
        # IPv4 pin: "localhost" also resolves to ::1, but the backend binds IPv4
        # only, so proxying to "localhost" lets nginx pick [::1] and intermittently
        # 502 (connection refused). Must stay 127.0.0.1.
        proxy_pass http://127.0.0.1:8000;
    }

    location /ws/ {
        proxy_pass http://127.0.0.1:8001;  # IPv4 pin (see note above)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

} 
