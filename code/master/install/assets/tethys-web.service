[Unit]
Description=Tethys Website
After=network.target

[Service]
ExecStart={TETHYS-PATH}/env_tethys/bin/gunicorn -c {TETHYS-PATH}/web/conf/gunicorn_config.py tethys_web.wsgi
WorkingDirectory={TETHYS-PATH}/web/
Environment="PATH={TETHYS-PATH}/env_tethys/bin"
StandardOutput=inherit
StandardError=inherit
Restart=always
#User=root

[Install]
WantedBy=multi-user.target
